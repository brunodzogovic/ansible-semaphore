# Copy this file to .env on the seed host and edit local values.
# Never commit the real .env file.

SEMAPHORE_VERSION=2.18.12
KUBESPRAY_REF=master

DB_USER=semaphore
DB_PASS=change-me
DB_HOST=mysql
DB_PORT=3306
DB_DIALECT=mysql
SEMAPHORE_DB=semaphore

SEMAPHORE_ADMIN_PASSWORD=change-me
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_NAME=admin
SEMAPHORE_ADMIN_EMAIL=admin@localhost

# Generate with: head -c 32 /dev/urandom | base64
# Keep stable after first deployment, otherwise stored Semaphore secrets/keys cannot be decrypted.
SEMAPHORE_ACCESS_KEY_ENCRYPTION=change-me-generated-once

DOCKER_REPOSITORY_NAME=brunodzogovic
CUSTOM_IMAGE_NAME=semaphore-kubespray
